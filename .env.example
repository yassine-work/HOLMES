APP_NAME="Holmes Verification Backend"
ENVIRONMENT="development"
DEBUG=true
API_V1_PREFIX="/api/v1"
ALLOWED_ORIGINS='["*"]'

SECRET_KEY="replace_with_secure_random_string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL="postgresql+asyncpg://<user>:<password>@<neon-host>/<db>?sslmode=require"
REDIS_URL="redis://localhost:6379/0"

CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_DEFAULT_MODEL="llama-3.3-70b-versatile"

SIGHTENGINE_API_USER=""
SIGHTENGINE_API_SECRET=""
ZENSERP_API_KEY=""
VIRUSTOTAL_API_KEY=""
NINJA_API_KEY=""

DEFAULT_ADMIN_EMAIL="admin@holmes.local"
DEFAULT_ADMIN_PASSWORD="ChangeMe_Admin123!"
